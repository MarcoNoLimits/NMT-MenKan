# Build Headers
/build/
/build_log.txt
/release_log.txt

# Visual Studio
.vs/
*.sln
*.vcxproj
*.vcxproj.user
*.ups

# CMake
CMakeCache.txt
CMakeFiles/

# Dependencies
/cmake/ctranslate2-src
/cmake/sentencepiece-src

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/

# Local vcpkg checkout (large; use submodule or separate clone if needed)
/vcpkg/

# CTranslate2 model folder (nllb_int8/) is tracked in Git; large blobs use LFS via .gitattributes.
# Install Git LFS (`git lfs install`) before cloning/pushing repos that include the model.

# Logs / local eval (avoid accidental `git add .` on Hugging Face deploy branch)
benchmark.log
server_eval.log
server_*.log
server_*.err
evaluation_report.txt
build_log*.txt
notes.txt

# Binary reports (Hugging Face rejects raw binaries; use LFS with -f if you must commit)
Report/*.pdf
Report/*.docx
